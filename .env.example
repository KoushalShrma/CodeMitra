# ======================================
# DATABASE
# ======================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=codemitra
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_root_password

# ======================================
# CLERK AUTH (Students / Developers)
# ======================================
VITE_ENABLE_CLERK_AUTH=false
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# ======================================
# JWT SECRETS
# ======================================
ADMIN_JWT_SECRET=your_admin_jwt_secret_minimum_32_chars
INSTITUTION_JWT_SECRET=your_institution_jwt_secret_minimum_32_chars
ADMIN_BOOTSTRAP_PASSWORD=your_bootstrap_admin_password

# ======================================
# GROQ AI API
# ======================================
GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_DAILY_BUDGET_USD=5.00
GROQ_MODEL=llama3-8b-8192
GROQ_MODEL_HINT=llama3-8b-8192
GROQ_MODEL_REVIEW=llama3-70b-8192
GROQ_MODEL_SUMMARY=llama3-8b-8192
GROQ_MODEL_CHAT=llama3-8b-8192

# ======================================
# JUDGE0 CODE EXECUTION
# ======================================
JUDGE0_RAPIDAPI_KEY=your_judge0_rapidapi_key_here
JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
JUDGE0_FALLBACK_ENDPOINT=https://ce.judge0.com

# ======================================
# EMAIL / SMTP
# ======================================
APP_MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_ADDRESS=your_sender_email
INSTITUTION_LOGIN_URL=http://localhost:5173/institution/login

# ======================================
# REDIS (optional)
# ======================================
REDIS_URL=disabled

# ======================================
# SCRAPER
# ======================================
SCRAPER_ENABLED=true
SCRAPER_WEEKLY_CRON=0 0 3 * * SUN
SCRAPER_MAX_ITEMS_PER_SOURCE=200
SCRAPER_REQUEST_DELAY_MS=600
SCRAPER_REQUEST_RETRIES=2

# ======================================
# FRONTEND
# ======================================
VITE_API_BASE_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000/api
SERVER_PORT=5000
